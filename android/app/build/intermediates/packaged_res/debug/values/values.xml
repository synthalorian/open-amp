<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="neon_accent">#D1F7FF</color>
    <color name="neon_bg">#0B0A16</color>
    <color name="neon_muted">#A7A2C7</color>
    <color name="neon_primary">#FF2A6D</color>
    <color name="neon_secondary">#05D9E8</color>
    <color name="neon_surface">#17132A</color>
    <color name="neon_text">#F8F7FF</color>
    <style name="OpenAmpButton" parent="Widget.AppCompat.Button">
        <item name="android:textColor">@color/neon_text</item>
        <item name="android:background">@drawable/bg_neon_button</item>
        <item name="android:paddingLeft">14dp</item>
        <item name="android:paddingRight">14dp</item>
    </style>
    <style name="Theme.OpenAmp" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">@color/neon_primary</item>
        <item name="colorPrimaryDark">@color/neon_surface</item>
        <item name="colorAccent">@color/neon_secondary</item>
        <item name="android:windowBackground">@color/neon_bg</item>
        <item name="android:textColor">@color/neon_text</item>
        <item name="android:textColorPrimary">@color/neon_text</item>
        <item name="android:textColorSecondary">@color/neon_muted</item>
        <item name="android:buttonStyle">@style/OpenAmpButton</item>
    </style>
</resources>